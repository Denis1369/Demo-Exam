<Window x:Class="Test.Page.OrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Test.Page"
        mc:Ignorable="d"
        Title="Заказы" Height="450" Width="800" Icon="/Data/Icon.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Image VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" Source="/Data/Icon.png"/>
        <Label VerticalAlignment="Center" HorizontalAlignment="Center" Content="«Обувь»" FontSize="30"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,30,0">
            <Label x:Name="NameLable" FontSize="25"/>
            <Button Margin="30,0,0,0" x:Name="AddButton" Width="70" Height="30" Content="Создать" FontSize="30" Background="Chartreuse" Click="AddButton_Click"/>
            <Button Margin="30,0,0,0" x:Name="MainButton" Width="70" Height="30" Content="Товары" FontSize="30" Background="Chartreuse" Click="MainButton_Click"/>
            <Button Margin="30,0,0,0" x:Name="BackButton" Width="70" Height="30" Content="Назад" FontSize="30" Background="Chartreuse" Click="BackButton_Click"/>
        </StackPanel>

        <ListBox x:Name="OrderList" Grid.Row="1" HorizontalContentAlignment="Stretch">
            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Редактировать" x:Name="ModButton" Click="ModButton_Click"/>
                    <MenuItem Header="Удалить" x:Name="DelButton" Click="DelButton_Click"/>
                </ContextMenu>
            </ListBox.ContextMenu>
        </ListBox>

    </Grid>
</Window>
