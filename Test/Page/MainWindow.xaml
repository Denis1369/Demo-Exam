<Window x:Class="Test.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Test" Icon="/Data/Icon.ico"
        mc:Ignorable="d"
        Title="Основоное окно" Height="450" Width="1000">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="70"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Image VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" Source="/Data/Icon.png"/>
        <Label VerticalAlignment="Center" HorizontalAlignment="Center" Content="«Обувь»" FontSize="30"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,30,0">
            <Label x:Name="NameLable" FontSize="25"/>
            <Button Margin="30,0,0,0" x:Name="BackButton" Width="60" Height="30" Content="Назад" FontSize="30" Background="Chartreuse" Click="BackButton_Click"/>
            <Button Margin="30,0,0,0" x:Name="AddButton" Width="70" Height="30" Content="Создать" FontSize="30" Background="Chartreuse" Click="AddButton_Click"/>
            <Button Margin="30,0,0,0" x:Name="OredrButton" Width="70" Height="30" Content="Заказы" FontSize="30" Background="Chartreuse" Click="OredrButton_Click" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="30,0,0,0">
            <Label Content="Фильтрация: "/>
            <ComboBox x:Name="FilterComboBox" DropDownClosed="FilterComboBox_DropDownClosed" SelectedIndex="0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
            <Label Content="Поиск: "/>
            <TextBox TextChanged="SerchTextBox_TextChanged" x:Name="SerchTextBox" Width="200"/>
        </StackPanel>

        <StackPanel Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">
            <Label Content="Сортировка: "/>
            <ComboBox DropDownClosed="SortComboBox_DropDownClosed" x:Name="SortComboBox" Margin="0,0,30,0" SelectedIndex="0"/>
        </StackPanel>


        <ListBox x:Name="ProductList" HorizontalContentAlignment="Stretch" Grid.Row="2">
            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Редактировать" Click="ModMenuItem_Click"/>
                    <MenuItem Header="Удалить" Click="DelMenuItem_Click"/>
                </ContextMenu>
            </ListBox.ContextMenu>
        </ListBox>
    </Grid>
</Window>
