<UserControl x:Class="Test.Card.OrderCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Test.Card"
             mc:Ignorable="d" 
             d:DesignHeight="200" d:DesignWidth="700">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <Border Margin="20" BorderBrush="White">
            <StackPanel Margin="10" Orientation="Vertical">
                <Button x:Name="OrderButton" Content="Состав заказа"
                    Width="200" Height="50" HorizontalAlignment="Left" 
                        VerticalAlignment="Top" Margin="10" Click="OrderButton_Click"/>

                <Label Content="{Binding OrdersId}" HorizontalAlignment="Left" 
                        VerticalAlignment="Top" Margin="10"/>

                <Label Content="{Binding Status}" HorizontalAlignment="Left" 
                        VerticalAlignment="Top" Margin="10"/>

                <Label Content="{Binding DeliviryPoint.TitleAll}" HorizontalAlignment="Left" 
        VerticalAlignment="Top" Margin="10"/>

                <Label Content="{Binding DateOrderS}" HorizontalAlignment="Left" 
        VerticalAlignment="Top" Margin="10"/>

            </StackPanel>
        </Border>

        <Label Content="{Binding DateDeliviryS}" Grid.Column="1" HorizontalAlignment="Center" 
VerticalAlignment="Center" Margin="10"/>
    </Grid>
</UserControl>
